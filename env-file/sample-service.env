# Sample application settings loaded by ECS from S3 at task startup.
# Each non-comment line becomes an environment variable inside the container.
# DEMO ONLY - these are not real secrets. This mirrors BeED's real pattern:
#   s3://acdstagingbucket/setting-<service>/<service>-<env>.env
APP_NAME=demo-api
APP_ENV=test
LOG_LEVEL=info
GREETING=Hello from the S3 env file
